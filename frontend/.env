# =========================================================
# TEACHER EVALUATION FRONTEND ENVIRONMENT
# =========================================================

# IMPORTANT:
# Restart Vite after modifying this file.
#
# Run:
# CTRL + C
# npm run dev

# =========================================================
# APPLICATION
# =========================================================

VITE_APP_NAME=Teacher Evaluation Platform
VITE_APP_SHORT_NAME=TeacherEval
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# =========================================================
# FRONTEND SERVER
# =========================================================

VITE_FRONTEND_HOST=localhost
VITE_FRONTEND_PORT=3000
VITE_FRONTEND_PROTOCOL=http
VITE_FRONTEND_URL=http://localhost:3000

# =========================================================
# BACKEND API
# =========================================================

# VERY IMPORTANT:
# NO trailing slash here

VITE_API_BASE_URL=http://127.0.0.1:8000

VITE_API_TIMEOUT=30000

VITE_API_VERSION=v1

# =========================================================
# API ENDPOINTS
# =========================================================

VITE_API_HEALTH_ENDPOINT=/evaluation/health
VITE_API_SINGLE_EVALUATION=/evaluation/evaluate
VITE_API_BATCH_EVALUATION=/evaluation/evaluate/batch
VITE_API_DEBUG_EVALUATION=/evaluation/evaluate/debug
VITE_API_MINIMAL_EVALUATION=/evaluation/evaluate/minimal
VITE_API_ADVANCED_EVALUATION=/evaluation/evaluate/advanced

# =========================================================
# DEBUG
# =========================================================

VITE_DEBUG_MODE=true
VITE_ENABLE_CONSOLE_LOGS=true
VITE_ENABLE_NETWORK_LOGS=true

# =========================================================
# DASHBOARD FEATURES
# =========================================================

VITE_ENABLE_DASHBOARD=true
VITE_ENABLE_BATCH_EVALUATION=true
VITE_ENABLE_INSIGHTS=true
VITE_ENABLE_CHARTS=true
VITE_ENABLE_HEALTH_MONITORING=true

# =========================================================
# SCORE CONFIGURATION
# =========================================================

VITE_SCORE_MAX=100
VITE_SCORE_MIN=0

VITE_SELECTED_THRESHOLD=85
VITE_STRONG_THRESHOLD=70
VITE_REVIEW_THRESHOLD=55

# =========================================================
# STATUS
# =========================================================

VITE_STATUS_SELECTED=SELECTED
VITE_STATUS_STRONG=STRONG
VITE_STATUS_REVIEW=REVIEW
VITE_STATUS_REJECTED=REJECTED

# =========================================================
# THEME
# =========================================================

VITE_DEFAULT_THEME=dark

VITE_PRIMARY_COLOR=#6c8cff
VITE_SUCCESS_COLOR=#10b981
VITE_WARNING_COLOR=#f59e0b
VITE_DANGER_COLOR=#ef4444

# =========================================================
# CHARTS
# =========================================================

VITE_ENABLE_RECHARTS=true
VITE_CHART_ANIMATION_DURATION=700

# =========================================================
# LOADING
# =========================================================

VITE_LOADING_DELAY=200
VITE_ENABLE_LOADING_ANIMATIONS=true

# =========================================================
# ERROR HANDLING
# =========================================================

VITE_ENABLE_ERROR_BOUNDARY=true
VITE_SHOW_ERROR_DETAILS=true

# =========================================================
# TOASTS
# =========================================================

VITE_ENABLE_TOAST_NOTIFICATIONS=true
VITE_TOAST_DURATION=4000

# =========================================================
# CACHE
# =========================================================

VITE_ENABLE_CACHE=false

# =========================================================
# HEALTH CHECKS
# =========================================================

VITE_ENABLE_HEALTH_CHECKS=true
VITE_HEALTH_CHECK_INTERVAL=30000

# =========================================================
# PERFORMANCE
# =========================================================

VITE_ENABLE_CODE_SPLITTING=true
VITE_ENABLE_LAZY_LOADING=true

# =========================================================
# ROUTING
# =========================================================

VITE_DEFAULT_ROUTE=/dashboard

# =========================================================
# DEVELOPMENT
# =========================================================

VITE_DEVTOOLS_ENABLED=true
VITE_ENABLE_HMR=true
VITE_FAST_REFRESH=true

# =========================================================
# LOCAL STORAGE KEYS
# =========================================================

VITE_STORAGE_THEME_KEY=teacher_eval_theme
VITE_STORAGE_CACHE_KEY=teacher_eval_cache

# =========================================================
# DEPLOYMENT
# =========================================================

VITE_DEPLOYMENT_TARGET=local

# =========================================================
# END
# =========================================================